{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "baseUrl": ".",
    "paths": {
      "@expo/vector-icons": ["./node_modules/expo/node_modules/@expo/vector-icons"],
      "@features/*": ["./src/features/*"],
      "@shared/*": ["./src/shared/*"],
      "@design/*": ["./src/design/*"]
    }
  }
}
