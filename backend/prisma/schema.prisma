generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PATIENT
  DOCTOR
  DONOR
  ADMIN
}

enum AppointmentStatus {
  UPCOMING
  COMPLETED
  CANCELLED
}

enum NotificationStatus {
  UNREAD
  READ
}

enum NotificationType {
  APPOINTMENT_BOOKED
  APPOINTMENT_CANCELLED
  APPOINTMENT_RESCHEDULED
  PRESCRIPTION_CREATED
  LAB_ORDER_CREATED
  LAB_ORDER_SUBMITTED
  GENERAL
}

enum PrescriptionStatus {
  ACTIVE
  INACTIVE
}

enum LabOrderStatus {
  PENDING
  SUBMITTED
  COMPLETED
}

enum VideoProvider {
  DAILY
}

enum VideoSessionStatus {
  CREATED
  ACTIVE
  ENDED
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  phoneCountryCode String?
  phone     String?
  passwordHash String
  role      Role
  firstName String
  lastName  String
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patientProfile PatientProfile?
  doctorProfile  DoctorProfile?

  appointmentsAsPatient Appointment[] @relation("PatientAppointments")
  appointmentsAsDoctor  Appointment[] @relation("DoctorAppointments")

  emailOtps EmailOtp[]
  passwordResets PasswordReset[]

  notifications Notification[]

  prescriptionsAsPatient Prescription[] @relation("PatientPrescriptions")
  prescriptionsAsDoctor  Prescription[] @relation("DoctorPrescriptions")

  labOrdersAsPatient LabOrder[] @relation("PatientLabOrders")
  labOrdersAsDoctor  LabOrder[] @relation("DoctorLabOrders")

  @@unique([phoneCountryCode, phone])
}

model EmailOtp {
  id        String   @id @default(cuid())
  userId    String
  email     String
  codeHash  String
  purpose   String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, purpose, expiresAt])
  @@index([userId, purpose])
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  email     String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, expiresAt])
  @@index([userId])
}

model PatientProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileData Json?
  onboardingCompletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DoctorProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialties String[] @default([])
  bio        String?
  avatarUri  String?
  availabilitySettings Json?
  availabilitySetAt DateTime?
  medicalCertificate String?
  boardCertificate String?
  deaRegistration String?
  malpracticeInsurance String?
  onboardingCompletedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Appointment {
  id        String            @id @default(cuid())
  patientId String
  doctorId  String
  status    AppointmentStatus @default(UPCOMING)
  startsAt  DateTime
  endsAt    DateTime
  reason    String?
  notes     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  patient User @relation("PatientAppointments", fields: [patientId], references: [id], onDelete: Cascade)
  doctor  User @relation("DoctorAppointments", fields: [doctorId], references: [id], onDelete: Cascade)

  videoSession VideoSession?
  soapNote SoapNote?
  reviews  Review[]
  prescriptions Prescription[]
  labOrders     LabOrder[]

  @@index([patientId, status])
  @@index([doctorId, status])
  @@unique([doctorId, startsAt])
}

model VideoSession {
  id            String             @id @default(cuid())
  appointmentId String             @unique
  provider      VideoProvider      @default(DAILY)
  status        VideoSessionStatus @default(CREATED)
  roomName      String             @unique
  roomUrl       String
  startedAt     DateTime?
  endedAt       DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([provider, status])
}

model Notification {
  id        String             @id @default(cuid())
  userId    String
  status    NotificationStatus @default(UNREAD)
  type      NotificationType
  title     String
  message   String
  data      Json?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
}

model SoapNote {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  subjective    String?
  objective     String?
  assessment    String?
  plan          String?
  diagnoses        Json?
  recommendedTests Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Prescription {
  id            String             @id @default(cuid())
  patientId     String
  doctorId      String
  appointmentId String?
  medication    String
  brandName     String?
  dose          String
  frequency     String
  duration      String
  route         String
  refillsLeft   Int                @default(0)
  totalRefills  Int                @default(0)
  notes         String?
  status        PrescriptionStatus @default(ACTIVE)
  rxNumber      String             @unique
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  patient     User         @relation("PatientPrescriptions", fields: [patientId], references: [id], onDelete: Cascade)
  doctor      User         @relation("DoctorPrescriptions", fields: [doctorId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([patientId, status])
  @@index([doctorId])
  @@index([appointmentId])
}

model LabOrder {
  id                    String         @id @default(cuid())
  patientId             String
  doctorId              String
  appointmentId         String?
  testName              String
  testType              String?
  priority              String?
  sampleType            String?
  collectionInstruction String?
  additionalComment     String?
  status                LabOrderStatus @default(PENDING)
  submittedFiles        Json           @default("[]")
  submittedAt           DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  patient     User         @relation("PatientLabOrders", fields: [patientId], references: [id], onDelete: Cascade)
  doctor      User         @relation("DoctorLabOrders", fields: [doctorId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([patientId, status])
  @@index([doctorId, status])
  @@index([appointmentId])
}

model Review {
  id            String      @id @default(cuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  rating        Int
  comment       String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([appointmentId])
}

