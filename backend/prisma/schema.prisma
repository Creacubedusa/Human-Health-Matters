generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PATIENT
  DOCTOR
  DONOR
  ADMIN
}

enum AppointmentStatus {
  UPCOMING
  COMPLETED
  CANCELLED
}

enum NotificationStatus {
  UNREAD
  READ
}

enum NotificationType {
  APPOINTMENT_BOOKED
  APPOINTMENT_CANCELLED
  APPOINTMENT_RESCHEDULED
  GENERAL
}

enum VideoProvider {
  DAILY
}

enum VideoSessionStatus {
  CREATED
  ACTIVE
  ENDED
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  phoneCountryCode String?
  phone     String?
  passwordHash String
  role      Role
  firstName String
  lastName  String
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patientProfile PatientProfile?
  doctorProfile  DoctorProfile?

  appointmentsAsPatient Appointment[] @relation("PatientAppointments")
  appointmentsAsDoctor  Appointment[] @relation("DoctorAppointments")

  emailOtps EmailOtp[]
  passwordResets PasswordReset[]

  notifications Notification[]

  @@unique([phoneCountryCode, phone])
}

model EmailOtp {
  id        String   @id @default(cuid())
  userId    String
  email     String
  codeHash  String
  purpose   String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, purpose, expiresAt])
  @@index([userId, purpose])
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  email     String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, expiresAt])
  @@index([userId])
}

model PatientProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileData Json?
  onboardingCompletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DoctorProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialties String[] @default([])
  bio        String?
  avatarUri  String?
  medicalCertificate String?
  boardCertificate String?
  deaRegistration String?
  malpracticeInsurance String?
  onboardingCompletedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Appointment {
  id        String            @id @default(cuid())
  patientId String
  doctorId  String
  status    AppointmentStatus @default(UPCOMING)
  startsAt  DateTime
  endsAt    DateTime
  reason    String?
  notes     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  patient User @relation("PatientAppointments", fields: [patientId], references: [id], onDelete: Cascade)
  doctor  User @relation("DoctorAppointments", fields: [doctorId], references: [id], onDelete: Cascade)

  videoSession VideoSession?
  soapNote SoapNote?
  reviews  Review[]

  @@index([patientId, status])
  @@index([doctorId, status])
}

model VideoSession {
  id            String             @id @default(cuid())
  appointmentId String             @unique
  provider      VideoProvider      @default(DAILY)
  status        VideoSessionStatus @default(CREATED)
  roomName      String             @unique
  roomUrl       String
  startedAt     DateTime?
  endedAt       DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([provider, status])
}

model Notification {
  id        String             @id @default(cuid())
  userId    String
  status    NotificationStatus @default(UNREAD)
  type      NotificationType
  title     String
  message   String
  data      Json?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
}

model SoapNote {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  subjective    String?
  objective     String?
  assessment    String?
  plan          String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Review {
  id            String      @id @default(cuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  rating        Int
  comment       String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([appointmentId])
}

